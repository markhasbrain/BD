# ============================================================
# USING WITH AI
# ============================================================
00000110 2 "05 // using with ai"
01000010 "var(--white)"
01000011 "22px"
01100101 "700"
01000101 "0 0 20px 0"
00000100

00000101 "bd was designed for ai to write. give your ai this prompt:"
01000010 "var(--gray5)"
01000011 "14px"
01000101 "0 0 20px 0"
00000100

00101001
01000001 "var(--gray1)"
01000111 "1px solid var(--gray2)"
01000110 "20px"
01000011 "14px"
01011011 "1.8"
01000010 "var(--gray6)"

11011010 "You write BD (.bd files), a binary language that replaces"
11011010 "HTML, CSS, and JS. Every instruction is an 8-bit opcode."
11011010 ""
11011010 "Categories:"
11011010 "  00 = structure (div, p, h1, a, img, button)"
11011010 "  01 = style (color, font-size, margin, flex, grid)"
11011010 "  10 = logic (onclick, timer, fetch)"
11011010 "  11 = meta (title, class, id, global css, keyframes)"
11011010 ""
11011010 "Rules:"
11011010 "  - One .bd file = one complete website"
11011010 "  - Every element opened must be closed (SECTION_START/END)"
11011010 "  - Style opcodes apply to the current element on the stack"
11011010 "  - Use GLOBAL_STYLE for reusable css rules"
11011010 "  - Use CUSTOM_CSS for any css property not in the opcodes"
11011010 ""
11011010 "Run 'bd info' for the full opcode reference."

00101010

00000101 "________________________________________"
01000010 "var(--gray3)"
01000011 "14px"
01000101 "48px 0 48px 0"
00000100

# ============================================================
# PURE BINARY MODE
# ============================================================
00000110 2 "06 // pure binary mode"
01000010 "var(--white)"
01000011 "22px"
01100101 "700"
01000101 "0 0 20px 0"
00000100

00000101 "bd can encode readable .bd files into pure binary -- a wall of 0s and 1s with no human text. common characters get shorter codes."
01000010 "var(--gray5)"
01000011 "14px"
01000101 "0 0 20px 0"
00000100

00101001
01000001 "var(--gray1)"
01000111 "1px solid var(--gray2)"
01000110 "20px"
01000011 "14px"
01011011 "1.8"

11011010 "bd encode landing.bd                # -> landing.bin.bd"
11011010 "bd decode landing.bin.bd             # -> landing.bd"
11011010 "bd compile landing.bin.bd            # works directly"

00101010

00000101 "the compiler reads both formats. encode for distribution. decode for editing."
01000010 "var(--gray4)"
01000011 "13px"
01000101 "20px 0 0 0"
00000100

00000100

