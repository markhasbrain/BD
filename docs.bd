# ============================================================
# INSTALL
# ============================================================
00000110 2 "01 // install"
01000010 "var(--white)"
01000011 "22px"
01100101 "700"
01000101 "0 0 20px 0"
00000100

00000101 "BD is a single binary. no package managers, no npm, no pip. clone and compile."
01000010 "var(--gray5)"
01000011 "14px"
01000101 "0 0 20px 0"
00000100

00101001
01000001 "var(--gray1)"
01000111 "1px solid var(--gray2)"
01000110 "20px"
01000011 "14px"
01011011 "1.8"

11011010 "git clone https://github.com/markhasbrain/BD.git"
11011010 "cd BD"
11011010 ""
11011010 "# windows (msys2/mingw)"
11011010 "g++ -std=c++20 -O2 src/main.cpp -lws2_32 -o bd.exe"
11011010 ""
11011010 "# linux / macos"
11011010 "g++ -std=c++20 -O2 src/main.cpp -o bd"

00101010

00000101 "that's it. one command. zero dependencies."
01000010 "var(--gray4)"
01000011 "13px"
01000101 "20px 0 48px 0"
00000100

00000101 "________________________________________"
01000010 "var(--gray3)"
01000011 "14px"
01000101 "0 0 48px 0"
00000100

# ============================================================
# YOUR FIRST .BD FILE
# ============================================================
00000110 2 "02 // your first .bd file"
01000010 "var(--white)"
01000011 "22px"
01100101 "700"
01000101 "0 0 20px 0"
00000100

00000101 "create a file called hello.bd and write this:"
01000010 "var(--gray5)"
01000011 "14px"
01000101 "0 0 20px 0"
00000100

00101001
01000001 "var(--gray1)"
01000111 "1px solid var(--gray2)"
01000110 "20px"
01000011 "14px"
01011011 "1.8"

11011010 "<span style=\"color:#555\"># set page title</span>"
11011010 "<span style=\"color:#fff\">11000001</span> <span style=\"color:#888\">\"My First BD Site\"</span>"
11011010 ""
11011010 "<span style=\"color:#555\"># start document</span>"
11011010 "<span style=\"color:#fff\">00000001</span>"
11011010 ""
11011010 "<span style=\"color:#555\"># heading with style</span>"
11011010 "<span style=\"color:#fff\">00000110</span> <span style=\"color:#888\">1 \"hello, world\"</span>"
11011010 "<span style=\"color:#fff\">01000010</span> <span style=\"color:#888\">\"#fff\"</span>"
11011010 "<span style=\"color:#fff\">01000011</span> <span style=\"color:#888\">\"48px\"</span>"
11011010 "<span style=\"color:#fff\">01100101</span> <span style=\"color:#888\">\"700\"</span>"
11011010 "<span style=\"color:#fff\">01001110</span> <span style=\"color:#888\">\"center\"</span>"
11011010 "<span style=\"color:#fff\">00000100</span>"
11011010 ""
11011010 "<span style=\"color:#555\"># paragraph</span>"
11011010 "<span style=\"color:#fff\">00000101</span> <span style=\"color:#888\">\"built entirely in binary.\"</span>"
11011010 "<span style=\"color:#fff\">01000010</span> <span style=\"color:#888\">\"#999\"</span>"
11011010 "<span style=\"color:#fff\">01001110</span> <span style=\"color:#888\">\"center\"</span>"
11011010 "<span style=\"color:#fff\">00000100</span>"
11011010 ""
11011010 "<span style=\"color:#555\"># end document</span>"
11011010 "<span style=\"color:#fff\">00000010</span>"

00101010

00000101 "now compile and serve it:"
01000010 "var(--gray5)"
01000011 "14px"
01000101 "20px 0 20px 0"
00000100

00101001
01000001 "var(--gray1)"
01000111 "1px solid var(--gray2)"
01000110 "20px"
01000011 "14px"
01011011 "1.8"

11011010 "bd compile hello.bd        # outputs hello.html"
11011010 "bd serve hello.bd          # dev server on localhost:5000"

00101010

00000101 "________________________________________"
01000010 "var(--gray3)"
01000011 "14px"
01000101 "48px 0 48px 0"
