01000101 "0 0 12px 0"
00000100

00101001
01000001 "var(--gray1)"
01000111 "1px solid var(--gray2)"
01000110 "20px"
01000011 "13px"
01011011 "1.8"

11011010 "00000001          DOC_START          start document"
11011010 "00000010          DOC_END            end document"
11011010 "00000011          SECTION_START      open a div"
11011010 "00000100          SECTION_END        close a div"
11011010 "00000101 \"text\"   TEXT               paragraph"
11011010 "00000110 N \"text\" HEADING            h1-h6 (N = level)"
11011010 "00000111 url text LINK               anchor tag"
11011010 "00001000 src alt  IMAGE              img tag"
11011010 "00001100 type ph  INPUT              input field"
11011010 "00001101 \"text\"   BUTTON             button"
11011010 "00010000/01       NAV_START/END      nav element"
11011010 "00010010/11       FOOTER_START/END   footer element"
11011010 "00010100/01       SPAN/SPAN_END      inline span"

00101010

00000110 3 "style"
01000010 "var(--gray5)"
01000011 "14px"
01100101 "600"
01000101 "24px 0 12px 0"
00000100

00101001
01000001 "var(--gray1)"
01000111 "1px solid var(--gray2)"
01000110 "20px"
01000011 "13px"
01011011 "1.8"

11011010 "01000001 val      BG                 background"
11011010 "01000010 val      COLOR              text color"
11011010 "01000011 val      FONT_SIZE          font size"
11011010 "01000101 val      MARGIN             margin"
11011010 "01000110 val      PADDING            padding"
11011010 "01001000 val      WIDTH              width"
11011010 "01001010 val      DISPLAY            display mode"
11011010 "01001110 val      ALIGN              text-align + margin auto"
11011010 "01010000 val      RADIUS             border-radius"
11011010 "01010011 val      TRANSITION         transition"
11011010 "01011111 val      JUSTIFY            justify-content"
11011010 "01110000 val      ALIGN_ITEMS        align-items"
11011010 "01110111 val      GRID_TEMPLATE      grid-template-columns"
11011010 "01100110 k v      CUSTOM_CSS         any css property"

00101010

00000110 3 "meta"
01000010 "var(--gray5)"
01000011 "14px"
01100101 "600"
01000101 "24px 0 12px 0"
00000100

00101001
01000001 "var(--gray1)"
01000111 "1px solid var(--gray2)"
01000110 "20px"
01000011 "13px"
01011011 "1.8"

11011010 "11000001 val      TITLE              page title"
11011010 "11001001 val      ID                 element id"
11011010 "11001010 val      CLASS              element class"
11011010 "11001011 k v      ATTR               any attribute"
11011010 "11010011 sel      GLOBAL_STYLE       start global css rule"
11011010 "11010100          GLOBAL_STYLE_END   end global css rule"
11011010 "11010101 sel      HOVER_STYLE        start :hover rule"
11011010 "11010110          HOVER_STYLE_END    end :hover rule"
11011010 "11001111 name     KEYFRAMES          start @keyframes"
11011010 "11010001          KEYFRAMES_END      end @keyframes"
11011010 "11011011 css      RAW_CSS            inject raw css"
11011010 "11011100 js       RAW_JS             inject raw js"

