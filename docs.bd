# ============================================================
# OPCODE REFERENCE
# ============================================================
00000110 2 "03 // how opcodes work"
01000010 "var(--white)"
01000011 "22px"
01100101 "700"
01000101 "0 0 20px 0"
00000100

00000101 "every instruction starts with an 8-bit opcode. the first two bits tell you the category:"
01000010 "var(--gray5)"
01000011 "14px"
01000101 "0 0 24px 0"
00000100

# Opcode categories
00101001
01000001 "var(--gray1)"
01000111 "1px solid var(--gray2)"
01000110 "20px"
01000011 "14px"
01011011 "1.8"

11011010 "<span style=\"color:#fff\">00xxxxxx</span>  structure    (div, p, h1, a, img, button...)"
11011010 "<span style=\"color:#fff\">01xxxxxx</span>  style        (color, font, margin, flex, grid...)"
11011010 "<span style=\"color:#fff\">10xxxxxx</span>  logic        (onclick, timer, fetch, dom...)"
11011010 "<span style=\"color:#fff\">11xxxxxx</span>  meta         (title, class, id, keyframes...)"

00101010

00000101 "parameters follow the opcode on the same line. strings go in quotes. numbers are bare."
01000010 "var(--gray5)"
01000011 "14px"
01000101 "20px 0 48px 0"
00000100

00000101 "________________________________________"
01000010 "var(--gray3)"
01000011 "14px"
01000101 "0 0 48px 0"
00000100

