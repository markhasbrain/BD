11011010 "<code>"
11011010 "<span style=\"color:#555\">  # page title</span>"
11011010 "  <span style=\"color:#fff\">11000001</span> <span style=\"color:#888\">\"Hello World\"</span>"
11011010 ""
11011010 "<span style=\"color:#555\">  # document</span>"
11011010 "  <span style=\"color:#fff\">00000001</span>"
11011010 ""
11011010 "<span style=\"color:#555\">  # heading</span>"
11011010 "  <span style=\"color:#fff\">00000110</span> <span style=\"color:#888\">1</span> <span style=\"color:#888\">\"Hello from BD\"</span>"
11011010 "  <span style=\"color:#fff\">01000010</span> <span style=\"color:#888\">\"#fff\"</span>"
11011010 "  <span style=\"color:#fff\">01000011</span> <span style=\"color:#888\">\"48px\"</span>"
11011010 "  <span style=\"color:#fff\">00000100</span>"
11011010 ""
11011010 "<span style=\"color:#555\">  # paragraph</span>"
11011010 "  <span style=\"color:#fff\">00000101</span> <span style=\"color:#888\">\"Built with binary.\"</span>"
11011010 ""
11011010 "<span style=\"color:#555\">  # end</span>"
11011010 "  <span style=\"color:#fff\">00000010</span>"
11011010 "</code>"

