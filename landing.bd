# --- META ---
11000001 "BD - Binary Decoder"
11000010 "UTF-8"
11000011 "width=device-width, initial-scale=1.0"
11000100 "One .bd file = One complete website. Pure binary. From scratch."
11000110 "https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700;800&display=swap"

# --- CSS VARIABLES ---
