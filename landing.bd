# ============================================================
# JS - Infinite binary rain
# ============================================================
# Generate binary, clone it for seamless loop, animate with JS
11011100 "var bg=document.getElementById('bg-binary');if(bg){var s='';for(var i=0;i<30000;i++){s+=Math.random()>0.5?'1':'0';}bg.textContent=s+s;var h=bg.scrollHeight/2;var y=0;function tick(){y-=0.4;if(y<=-h)y=0;bg.style.transform='translateY('+y+'px)';requestAnimationFrame(tick);}tick();}"

# Smooth scroll
11011100 "document.querySelectorAll('a[href^=\"#\"]').forEach(function(a){a.addEventListener('click',function(e){e.preventDefault();var t=document.querySelector(this.getAttribute('href'));if(t)t.scrollIntoView({behavior:'smooth',block:'start'});});});"
